# Required — path to your WoW 3.3.5a installation
WOW_INSTALL_PATH=/path/to/World of Warcraft

# Required — WoW account name (found in WTF/Account/<name>/)
WOW_ACCOUNT_NAME=

# Optional — Claude model to use (opus, sonnet, haiku)
ALDRICBOT_MODEL=haiku

# Optional — hours before conversation context resets (default: 24)
ALDRICBOT_SESSION_TTL=24

# Optional — admin character name for privileged whisper commands
ALDRICBOT_ADMIN=

# Optional — character name for greeting prefix and memory isolation (default: Aldric)
ALDRICBOT_CHARACTER=Aldric

# Optional — path to persona YAML file (e.g., personas/aldric.yaml)
ALDRICBOT_PERSONA=

# Optional — enable/disable idle emotes (default: true)
ALDRICBOT_IDLE_EMOTES=true

# Optional — enable/disable proactive RP messages (default: true)
ALDRICBOT_PROACTIVE_RP=true

# Optional — idle emote cadence as MIN-MAX in minutes (default: 8-12)
ALDRICBOT_EMOTE_CADENCE=8-12

# Optional — proactive RP cadence as MIN-MAX in minutes (default: 120-240)
ALDRICBOT_PROACTIVE_CADENCE=120-240
