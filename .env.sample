# Required — path to your WoW 3.3.5a installation
WOW_INSTALL_PATH=/path/to/World of Warcraft

# Required — WoW account name (found in WTF/Account/<name>/)
WOW_ACCOUNT_NAME=

# Optional — Claude model to use (opus, sonnet, haiku)
ALDRICBOT_MODEL=haiku

# Optional — hours before conversation context resets (default: 24)
ALDRICBOT_SESSION_TTL=24

# Optional — admin character name for privileged whisper commands
ALDRICBOT_ADMIN=
